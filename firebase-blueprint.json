{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and API keys.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role for access control." },
        "openaiKey": { "type": "string", "description": "User's personal OpenAI API key." },
        "anthropicKey": { "type": "string", "description": "User's personal Anthropic API key." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document containing their private API keys."
    }
  }
}
